    "dev:studio": "prisma studio --schema=prisma/schema.prisma",
    "prod:migrate": "prisma migrate deploy --schema=schema.prod.prisma",
    "prod:generate": "prisma generate --schema=schema.prod.prisma",
    "build": "prisma generate --schema=schema.prod.prisma && tsc",
    "start": "node dist/index.js",
    "postinstall": "prisma generate --schema=schema.prod.prisma || true",
